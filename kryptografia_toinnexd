# GŁÓWNA LOGIKA PROGRAMU - PRZETWARZANIE WEJŚCIA
# ==========================================
if __name__ == '__main__':
    # Pobieramy całe wejście i dzielimy je na osobne linijki kodu.
    # Używamy splitlines(), aby przetwarzać dane wiersz po wierszu.
    lines = sys.stdin.read().splitlines()
    # Czyścimy wejście z pustych, technicznych linii z końca pliku
    lines = [line.strip() for line in lines if line.strip()]
    
    if len(lines) >= 4:
        # ----------------------------------------------------
        # KROK 1: FAKTORYZACJA i KLUCZ RSA (Linia 1)
        # ----------------------------------------------------
        # Wyciągamy 'n' i 'e' i konwertujemy na liczby całkowite
        n, e = map(int, lines[0].split())
        
        # Odtwarzamy czynniki pierwsze
        p, q = factor(n)
        
        # Wyliczamy funkcję Eulera phi(n) - kluczowe dla RSA
        phi_n = (p - 1) * (q - 1)
        
        # Obliczamy klucz prywatny 'd'
        d = mod_inv(e, phi_n)
        
        # Wypisujemy rozwiązanie pierwszego kroku
        print(f"{p} {q} {d}")
        
        # ----------------------------------------------------
        # KROK 2: DESZYFROWANIE BLOKÓW RSA (Linia 2)
        # ----------------------------------------------------
        # Wyciągamy zaszyfrowane bloki (może być ich wiele) z drugiej linii wejścia
        blocks = list(map(int, lines[1].split()))
        
        # Deszyfrujemy każdy blok matematycznie: c^d mod n
        # Używamy list comprehension dla zwięzłości
        decrypted_blocks = [modExp(c, d, n) for c in blocks]
        
        # Łączymy odszyfrowane liczby spacjami i wypisujemy
        print(" ".join(map(str, decrypted_blocks)))
        
        # ----------------------------------------------------
        # KROK 3: ŁAMANIE DYSKRETNEGO LOGARYTMU (Linia 3)
        # ----------------------------------------------------
        p_bsgs, g_bsgs, A_bsgs = map(int, lines[2].split())
        
        # Wywołujemy algorytm BSGS zdefiniowany wyżej
        x = bsgs(g_bsgs, A_bsgs, p_bsgs)
        print(x)
        
        # ----------------------------------------------------
        # KROK 4: WERYFIKACJA PODPISU ELGAMALA (Linia 4)
        # ----------------------------------------------------
        p2, g2, y, m_el, s1, s2 = map(int, lines[3].split())
        
        # Algorytm weryfikacji ElGamala polega na sprawdzeniu, czy:
        # g^m == (y^s1 * s1^s2) mod p
        
        # Lewa strona równania: g^m mod p
        left_side = modExp(g2, m_el, p2)
        
        # Prawa strona: musimy wymnożyć dwa szybkie potęgowania i ponownie zmodulować
        right_side = (modExp(y, s1, p2) * modExp(s1, s2, p2)) % p2
        
        # Weryfikacja: jeśli obie strony są sobie równe, podpis złożyła właściwa osoba.
        if left_side == right_side:
            print("valid")
        else:
            print("invalid")
